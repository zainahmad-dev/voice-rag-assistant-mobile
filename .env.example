# Copy this file to .env and fill in the values.
#
# Variables prefixed with EXPO_PUBLIC_ are inlined into the app bundle at
# build time and are readable by anyone with the app — never put secrets here.

# Base URL of the deployed voice-rag-assistant backend
EXPO_PUBLIC_API_URL=https://voice-rag-assistant-blush.vercel.app

# VAPI public (client) key — from dashboard.vapi.ai > Organization > API Keys.
# This is the public key, which can only start calls; never use the private key.
EXPO_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key_here
